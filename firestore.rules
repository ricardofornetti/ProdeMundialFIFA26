rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Authentication helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'fornettiricardo@gmail.com' ||
        request.auth.token.email == 'FORNETTIRICARDO@GMAIL.COM'
      );
    }

    // Official Match Schedule data
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // User Predictions
    match /predictions/{predId} {
      allow read: if true;
      allow write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Usernames collection for unique constraint checks
    match /usernames/{username} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Private Groups
    match /groups/{groupId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
