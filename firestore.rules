rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: email or username
    // Fields:
    //   - username: string (required)
    //   - email: string (required, format: email)
    //   - photoUrl: string
    //   - isVerified: bool
    //   - totalScore: number
    //   - lastLogin: timestamp
    //   - lastUpdate: timestamp
    //   - updatedAt: timestamp
    //
    // Collection: groups
    // Document ID: groupId
    // Fields:
    //   - id: string
    //   - name: string
    //   - adminEmail: string
    //   - members: list of objects
    //   - memberEmails: list of strings
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // Collection: predictions
    // Document ID: userId_matchId
    // Fields:
    //   - userId: string
    //   - matchId: string
    //   - homeScore: number
    //   - awayScore: number
    //   - updatedAt: timestamp
    //
    // Collection: matches
    // Document ID: matchId
    // Fields:
    //   - id: string
    //   - homeTeam: string
    //   - awayTeam: string
    //   - actualHomeScore: number
    //   - actualAwayScore: number
    //
    // Collection: gallery_uploads
    // Document ID: auto-generated
    // Fields:
    //   - year: number
    //   - host: string
    //   - url: string
    //   - caption: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') || 
          (request.auth.token.email == "fornettiricardo@gmail.com") ||
          (request.auth.token.email == "FORNETTIRICARDO@GMAIL.COM") ||
          (request.auth.token.email == "ricardofornetti@hotmail.com.ar") ||
          (request.auth.token.email == "RICARDOFORNETTI@HOTMAIL.COM.AR")
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'role']) &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.email is string && data.email.size() > 5 &&
             data.role in ['admin', 'user'] &&
             (!('uid' in data) || data.uid == request.auth.uid);
    }

    function isValidPrediction(data) {
      return data.keys().hasAll(['userId', 'matchId', 'homeScore', 'awayScore']) &&
             data.userId is string &&
             data.matchId is string &&
             data.homeScore is number && data.homeScore >= 0 &&
             data.awayScore is number && data.awayScore >= 0 &&
             data.userId == request.auth.uid;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['id', 'name', 'adminEmail', 'members', 'memberEmails']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.memberEmails is list &&
             data.adminEmail == request.auth.token.email;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if true; // Allow anyone to check if a user exists by UID
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated() && (request.auth.token.email in resource.data.memberEmails || isAdmin());
      allow create: if isAuthenticated() && isValidGroup(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.token.email == resource.data.adminEmail || isAdmin()) && isValidGroup(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.token.email == resource.data.adminEmail || isAdmin());
    }

    match /predictions/{predictionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidPrediction(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /matches {
      allow read: if true;
      allow write: if isAdmin();
      match /{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /gallery_uploads {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
      match /{allPaths=**} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow delete: if isAdmin();
      }
    }
  }
}
